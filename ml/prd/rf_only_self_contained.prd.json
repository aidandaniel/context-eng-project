{
  "prd": {
    "id": "rf-only-self-contained-mcp",
    "version": "1.0.0",
    "title": "RF-Only Self-Contained Context MCP",
    "status": "approved",
    "created": "2026-06-30",
    "owner": "context-eng-project"
  },
  "problem": {
    "summary": "The MCP server must cut token costs on any single query while keeping the right files in context, using only the query text and open repo — no oracle anchor labels, no intent budget table, and no user-supplied file hints.",
    "current_gaps": [
      "Label generation uses hidden expected_anchors; runtime does not.",
      "Training uses relaxed retrieval config (40 inferred anchors); production uses 3.",
      "Intent budget table is still the default runtime budget source.",
      "RF eval gates compare against intent instead of absolute self-contained bars.",
      "RF confidence bump is tied to intent-table recommended budget."
    ]
  },
  "goal": {
    "statement": "On any singular query, discover anchor files from query + repo, include them in a budgeted bundle, and minimize tokens via RF — with no external help.",
    "success_criteria": [
      "Runtime uses RF for budget selection; intent table is not used at runtime.",
      "Training labels are derived from runtime-discovered anchors only.",
      "All four CI gates pass at mediocre baseline thresholds.",
      "prepare_context returns bundles containing discovered anchors without expected_anchors."
    ],
    "non_goals": [
      "Embedding-based anchor inference",
      "Corpus expansion in budget_training_queries.yaml",
      "Hyperparameter tuning beyond retrain-on-new-labels",
      "Raising gate thresholds above mediocre baseline",
      "Removing intent classifier (kept as RF feature + UI metadata)"
    ]
  },
  "runtime_policy": {
    "budget_resolution_order": [
      "explicit max_tokens on tool call",
      "rf_budget via ml/models/budget_rf_v2.joblib",
      "fallback: default_max_tokens (8000) snapped to nearest BUDGET_BUCKETS entry"
    ],
    "budget_source_default": "rf",
    "intent_table_at_runtime": false,
    "missing_model_fallback": "default_max_tokens",
    "external_inputs_forbidden": [
      "expected_anchors",
      "user-supplied anchor file lists",
      "intent budget table as ceiling"
    ]
  },
  "gates": {
    "blocking": [
      {
        "id": "TOKEN_REDUCTION_GATE",
        "metric": "median_reduction_pct",
        "dataset": "benchmarks/queries.yaml",
        "operator": ">=",
        "threshold": 30.0,
        "unit": "percent",
        "report_line_pattern": "TOKEN_REDUCTION_GATE: PASS"
      },
      {
        "id": "P90_LATENCY_GATE",
        "metric": "p90_latency_ms",
        "dataset": "benchmarks/queries.yaml",
        "operator": "<",
        "threshold": 3000.0,
        "unit": "milliseconds",
        "report_line_pattern": "P90_LATENCY_GATE: PASS"
      },
      {
        "id": "ANCHOR_RETENTION_GATE",
        "metric": "anchor_retention_rate",
        "dataset": "ml/data/budget_training_queries.yaml",
        "operator": ">=",
        "threshold": 0.9,
        "unit": "ratio",
        "report_line_pattern": "ANCHOR_RETENTION_GATE: PASS"
      },
      {
        "id": "RF_CV_GATE",
        "metric": "cv_overall_accuracy",
        "dataset": "ml/data/budget_labels.jsonl",
        "operator": ">=",
        "threshold": 0.25,
        "unit": "ratio",
        "report_line_pattern": "RF_CV_GATE: PASS"
      }
    ],
    "audit_only": [
      {
        "id": "oracle_anchor_recall",
        "metric": "oracle_anchor_recall",
        "ci_blocking": false
      }
    ],
    "removed": [
      "RF_ANCHOR_RECALL_GATE",
      "RF_AB_BENCHMARK_GATE"
    ]
  },
  "agent_loop": {
    "eval_command": "context-eng-ml-eval",
    "report_path": "ml/reports/rf_eval.md",
    "fix_prompt": "ml/prompts/fix_rf_eval.md",
    "gate_grep_patterns": [
      "TOKEN_REDUCTION_GATE: PASS",
      "P90_LATENCY_GATE: PASS",
      "ANCHOR_RETENTION_GATE: PASS",
      "RF_CV_GATE: PASS"
    ],
    "fail_grep_pattern": "GATE: FAIL",
    "regenerate_pipeline": [
      "context-eng-ml-labels",
      "context-eng-ml-train",
      "context-eng-ml-eval"
    ]
  },
  "verification": {
    "commands": [
      { "cmd": "pytest -m \"not benchmark\"", "expect_exit": 0 },
      { "cmd": "pytest -m benchmark", "expect_exit": 0 },
      { "cmd": "context-eng-ml-eval", "expect_exit": 0 },
      { "cmd": "./ml/scripts/validate_rf_self_contained_gates.sh", "expect_exit": 0 },
      { "cmd": "python -m mypy src/context_eng benchmarks", "expect_exit": 0 }
    ]
  },
  "budget_buckets": [2000, 3000, 4000, 5000, 6000, 8000, 10000, 12000, 15000]
}
